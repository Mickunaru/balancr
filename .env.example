# Copy to .env and fill in real values. Never commit .env.

# Neon pooled connection string (Dashboard → Connect → Pooled connection)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth session signing secret.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# AES-256-GCM key for encrypting Plaid access tokens at rest (64 hex chars).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# Google OAuth (optional — sign-in button appears when both are set)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
