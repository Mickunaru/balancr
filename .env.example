# Copy to .env and fill in real values. Never commit .env.

# Neon pooled connection string (Dashboard → Connect → Pooled connection)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth session signing secret.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# AES-256-GCM key for encrypting Plaid access tokens at rest (64 hex chars).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# Google OAuth (optional — sign-in button appears when both are set)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# Plaid. PLAID_ENV=sandbox for the public demo, production for real accounts.
# Keys from dashboard.plaid.com → Developers → Keys.
PLAID_ENV="sandbox"
PLAID_CLIENT_ID=""
PLAID_SECRET=""

# Public app URL for Plaid webhook registration (Vercel domain or ngrok tunnel).
# Leave unset for plain local dev - webhooks skipped, use Sync now instead.
# APP_URL=""
